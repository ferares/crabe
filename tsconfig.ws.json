{
  "compilerOptions": {
    "target": "es2015",
    "resolveJsonModule": true,
    "strict": false,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "module": "node16",
    "moduleResolution": "node16",
    "outDir": "./dist/server",
    "noEmit": false,
    "rootDir": "./src"
  },
  "include": [
    "./src/server/start.ts"
  ],
  "exclude": [
    "./src/client",
    "node_modules"
  ]
}